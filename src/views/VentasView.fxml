<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.VentasViewController">
   <children>
      <Label layoutX="14.0" layoutY="14.0" text="PRODUCTOS DISPONIBLES" />
      <TableView fx:id="tbvProductos" layoutX="14.0" layoutY="40.0" prefHeight="250.0" prefWidth="670.0">
        <columns>
          <TableColumn fx:id="colNombre" prefWidth="350.0" text="Nombre" />
          <TableColumn fx:id="colPrecio" prefWidth="160.0" text="Precio" />
            <TableColumn fx:id="colStock" prefWidth="160.0" text="Stock" />
        </columns>
      </TableView>
      <Label layoutX="14.0" layoutY="300.0" text="Cantidad:" />
      <TextField fx:id="txtCantidad" layoutX="80.0" layoutY="296.0" prefHeight="26.0" prefWidth="100.0" />
      <Button fx:id="btnAgregar" layoutX="190.0" layoutY="296.0" mnemonicParsing="false" onAction="#agregar" text="Agregar al Carrito" />
      <Label layoutX="14.0" layoutY="340.0" text="CARRITO DE COMPRAS" />
      <ListView fx:id="lsvCarrito" layoutX="14.0" layoutY="366.0" prefHeight="90.0" prefWidth="670.0" />
      <Button fx:id="btnFinalizarCompra" layoutX="570.0" layoutY="466.0" mnemonicParsing="false" onAction="#finalizarCompra" prefHeight="26.0" prefWidth="114.0" text="Finalizar Compra" />
   </children>
</AnchorPane>
